{
  "cli": {
    "version": ">= 1.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "channel": "preview"
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "distribution": "store",
      "autoIncrement": true,
      "channel": "production"
    },
    "apk": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "channel": "apk"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./keys/google-play-service-account.json",
        "track": "internal"
      }
    },
    "apk": {
      "android": {
        "serviceAccountKeyPath": "./keys/google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
