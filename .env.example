### RetinaAI - Example environment variables
# Copy this file to `.env` (client) and `.env.server` (server) and replace placeholders with real values.

# --- Client (Vite) - required for browser client
# Public (publishable) keys safe to expose to client runtime
VITE_SUPABASE_URL=https://ideewfgconyevfevhtgr.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# --- Server (use a separate server .env or process env for the backend)
# Supabase URL (same as VITE_SUPABASE_URL) - used by server code too
SUPABASE_URL=https://ideewfgconyevfevhtgr.supabase.co

# Supabase service role key (HIGHLY SENSITIVE) - use only on server
# Provide the Supabase service role key here or via secure host environment variables.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Alternate fallbacks (optional)
SUPABASE_ANON_KEY=your-anon-key

# Database connection used by Drizzle migrations and server
DATABASE_URL=postgres://user:password@host:5432/database

# Server port (optional)
PORT=5000

# Node environment
NODE_ENV=development

# --- DR Classifier (FastAPI on Hugging Face Spaces or any Docker host) ---
# Public URL of the deployed FastAPI service (see ml-backend/). When unset,
# uploads create a "Pending Analysis" stub row instead of calling the model.
DR_API_URL=https://your-username-dr-classifier.hf.space
# Optional shared secret. If set on the Space (env var DR_API_KEY) the server
# must send the same value as the `x-api-key` header.
DR_API_KEY=

# --- Mobile (Expo) - required for the React Native client ---
# Same Supabase project as the web client.
EXPO_PUBLIC_SUPABASE_URL=https://ideewfgconyevfevhtgr.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
# DR Classifier (mobile uses the same URL/key as the server above).
EXPO_PUBLIC_DR_API_URL=https://your-username-dr-classifier.hf.space
EXPO_PUBLIC_DR_API_KEY=
